# Byte-compiled / optimized files
__pycache__/
*.py[cod]
*$py.class

# Build / packaging artifacts
build/
dist/
*.egg-info/
.eggs/
*.egg

# Virtual environments
.venv/
venv/
env/
ENV/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# NOTE: MLatom intentionally tracks its compiled binaries and model weights
# (MLatomF, *.so, the bundled xtb, and mlatom_models/*.pt). Do NOT add blanket
# patterns such as "*.so" or "*.pt" here — they must remain versioned.
